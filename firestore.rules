rules_version = '2';
// Colecciones: users, rooms, roomMembers, roomJoinRequests,
// teams, matches, predictions, tournamentResults,
// standings/{roomId}/users/{userId}
// Escritura de matches, tournamentResults y standings: solo backend (Functions/admin SDK).

service cloud.firestore {
  match /databases/{database}/documents {
    function isPrivateRoomOwner(roomId) {
      return request.auth != null
        && roomId != 'global'
        && exists(/databases/$(database)/documents/rooms/$(roomId))
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.type == 'private'
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /predictionState/{roomId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'inviteCode', 'maxMembers', 'createdBy', 'type']);
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /roomMembers/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && membershipId == request.resource.data.roomId + '_' + request.resource.data.userId
        && request.resource.data.keys().hasAll(['roomId', 'userId', 'displayName'])
        && (
          request.resource.data.userId == request.auth.uid
          || isPrivateRoomOwner(request.resource.data.roomId)
        );
      allow update, delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || isPrivateRoomOwner(resource.data.roomId)
        );
    }

    match /roomJoinRequests/{requestId} {
      allow read: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || isPrivateRoomOwner(resource.data.roomId)
        );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['roomId', 'userId', 'displayName', 'status'])
        && exists(/databases/$(database)/documents/rooms/$(request.resource.data.roomId))
        && get(/databases/$(database)/documents/rooms/$(request.resource.data.roomId)).data.type == 'private';
      allow delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || isPrivateRoomOwner(resource.data.roomId)
        );
      allow update: if false;
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Predicciones generales: el usuario puede escribir las suyas hasta finalizar en esa sala.
    // player_per_match sigue permitido tras finalizar (ventana propia por partido).
    function predictionStatePath(roomId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/predictionState/$(roomId);
    }

    function isPredictionFinalizedInRoom(roomId) {
      return exists(predictionStatePath(roomId))
        && get(predictionStatePath(roomId)).data.get('predictionFinalized', false) == true;
    }

    function isSpecialPlayerQuestionId(questionId) {
      return questionId == 'extra_top_scorer'
        || questionId == 'special_best_goalkeeper_average';
    }

    // Goleador y arquero: mismo cierre que predicciones generales (11-jun-2026 12:00 Bogotá).
    // 11-jun-2026 12:00 America/Bogota (UTC-5) = 11-jun-2026 17:00 UTC.
    function specialPlayersLockAt() {
      return timestamp.date(2026, 6, 11) + duration.value(17, 'h');
    }

    function canWriteSpecialPlayersAfterFinalize() {
      return request.resource.data.scope == 'tournament'
        && isSpecialPlayerQuestionId(request.resource.data.questionId)
        && request.time < specialPlayersLockAt();
    }

    function playerPerMatchLockAt(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.scheduledAt
        - duration.value(1, 'h');
    }

    function canWritePlayerPerMatch() {
      return request.resource.data.scope == 'player_per_match'
        && request.resource.data.matchId is string
        && exists(/databases/$(database)/documents/matches/$(request.resource.data.matchId))
        && request.time < playerPerMatchLockAt(request.resource.data.matchId);
    }

    function canWritePredictionDoc(roomId) {
      return canWritePlayerPerMatch()
        || !isPredictionFinalizedInRoom(roomId)
        || canWriteSpecialPlayersAfterFinalize();
    }

    match /predictions/{predictionId} {
      allow read: if request.auth != null
        && (
          resource.data.roomId == 'global'
          || resource.data.userId == request.auth.uid
          || exists(
            /databases/$(database)/documents/roomMembers/$(resource.data.roomId + '_' + request.auth.uid)
          )
        );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && canWritePredictionDoc(request.resource.data.roomId);
      allow update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && resource.data.userId == request.auth.uid
        && canWritePredictionDoc(request.resource.data.roomId);
      allow delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || isPrivateRoomOwner(resource.data.roomId)
        );
    }

    match /tournamentResults/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /standings/{roomId}/users/{userId} {
      allow read: if request.auth != null;
      allow delete: if isPrivateRoomOwner(roomId);
      allow create, update: if false;
    }
  }
}
