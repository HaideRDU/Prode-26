# Copia este archivo a .env y rellena con tu app web en Firebase Console > Configuración del proyecto.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# GitHub Pages (repo de proyecto): misma base que en CI. Ej. repo "proyect-cursor" → /proyect-cursor/
# Solo para probar build local: VITE_BASE_PATH=/nombre-repo/ npm run build && npm run preview
# VITE_BASE_PATH=

# Seeds (Firebase Admin) — mismo proyecto que la app web
# Obligatorio: credenciales (sin esto el seed no escribe nada):
# GOOGLE_APPLICATION_CREDENTIALS=ruta/absoluta/al/serviceAccount.json
# Opcional: si lo dejas vacío, el seed usa VITE_FIREBASE_PROJECT_ID del .env como projectId
FIREBASE_PROJECT_ID=

# Despliegue de reglas: copia .firebaserc.example a .firebaserc y pon tu projectId; luego:
# npm run deploy:firestore-rules
