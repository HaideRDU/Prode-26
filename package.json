    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.0.0",
    "firebase-tools": "^14.0.0",
    "globals": "^17.4.0",
    "rollup-plugin-visualizer": "^6.0.11",
